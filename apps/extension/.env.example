# WXT inlines these at build time. Variables MUST be prefixed with WXT_
# to be exposed to the extension bundle.

# Production-only: register at https://www.inboxsdk.com/register and paste
# the APP_ID here. The dev fallback in src/config.ts works for local
# `wxt dev` testing without needing a real ID.
WXT_INBOXSDK_APP_ID=sdk_mailfalcon_prod_REPLACE_ME
